# Name of a concrete entry under `proxies` in clash.yaml. Proxy groups are not accepted.
CLASH_PROXY_NAME=example-vless-reality

# The unauthenticated SOCKS and HTTP ports bind locally by default. Set to 0.0.0.0 only
# when access is protected by a firewall or a trusted private network.
XRAY_BIND_ADDRESS=127.0.0.1
